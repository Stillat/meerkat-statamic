{
    "name": "stillat/meerkat",
    "description": "A comments and moderation addon for Statamic 6.",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Stillat\\Meerkat\\": "src"
        }
    },
    "authors": [
        {
            "name": "John Koster",
            "email": "john@stillat.com",
            "homepage": "https://stillat.com",
            "role": "Developer"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Stillat\\Meerkat\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.2",
        "statamic/cms": "^6.24.2",
        "ext-dom": "*",
        "league/csv": "^9.0",
        "nesbot/carbon": "^3.13",
        "spatie/invade": "^2.1",
        "symfony/http-foundation": "^7.4",
        "symfony/yaml": "^7.4",
        "ueberdosis/tiptap-php": "^2.0",
        "ext-libxml": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.9",
        "phpstan/extension-installer": "^1.4",
        "rector/rector": "^2.4",
        "driftingly/rector-laravel": "^2.3",
        "brianium/paratest": "~7.8.5"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "audit:licenses": "php scripts/audit-composer-licenses.php",
        "phpstan": "phpstan analyse --memory-limit=2G",
        "rector": "rector --dry-run",
        "rector:fix": "rector",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:feature": "phpunit --testsuite=Feature",
        "test:parallel": "paratest --exclude-group=performance",
        "test:parallel:random": "paratest --exclude-group=performance --order-by=random"
    },
    "extra": {
        "statamic": {
            "name": "Meerkat",
            "description": "Meerkat addon"
        },
        "laravel": {
            "providers": [
                "Stillat\\Meerkat\\ServiceProvider"
            ]
        }
    }
}
